{
  "name": "llm-tycoon",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "LLM Tycoon — game tycoon về xây dựng công ty AI, do chính LLM vận hành. Tài liệu game dạng module, build thành 1 file MD gửi cho LLM để chơi.",
  "module": "src/index.ts",
  "bin": {
    "llm-tycoon": "src/cli/main.tsx"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun run src/cli/main.tsx build",
    "build:full": "bun run src/cli/main.tsx build --keep-comments",
    "play": "bun run src/cli/main.tsx play",
    "play:new": "bun run src/cli/main.tsx play --new",
    "play:resume": "bun run src/cli/main.tsx play --resume",
    "play:continue": "bun run src/cli/main.tsx play --continue",
    "play:verbose": "bun run src/cli/main.tsx play --verbose",
    "play:plain": "bun run src/cli/main.tsx play --plain",
    "history": "bun run src/cli/main.tsx history",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-truncate": "^6.1.0",
    "ink": "^7.1.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "meow": "^14.1.0",
    "openai": "^6.45.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "typescript": "^6.0.3"
  }
}
